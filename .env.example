# External port exposed on the host.
# Open MATFLOTE at http://localhost:8080 by default.
# On a Raspberry Pi, use http://<pi-ip>:8080 from phones/tablets on the same LAN.
MATFLOTE_PORT=8080

# Shopping list export provider.
# Vikunja is the first supported provider. Other todo systems can be added later.
SHOPPING_LIST_EXPORT_PROVIDER=Vikunja

# Vikunja task layout.
# SingleTask creates one Vikunja task with a checklist.
# SeparateTasks creates one Vikunja task per ingredient.
SHOPPING_LIST_EXPORT_TASK_MODE=SingleTask

# Vikunja integration.
# Keep the real API token only in your local .env or server environment.
# Dev PC example, when connected through Tailscale:
# VIKUNJA_BASE_URL=https://vikunja.example.com
# VIKUNJA_PROJECT_ID=3
# VIKUNJA_API_TOKEN=your-token-here
VIKUNJA_BASE_URL=
VIKUNJA_PROJECT_ID=
VIKUNJA_API_TOKEN=

# Kassalapp product lookup for the Scanner/Skanner page.
# Keep the real API key only in your local .env or server environment.
KASSALAPP_API_KEY=

# Helsedirektoratet HAPI lookup for official nutrition reference values.
# Keep the real subscription key only in your local .env or server environment.
# QA portal keys use https://api-qa.helsedirektoratet.no.
# Production portal keys use https://api.helsedirektoratet.no.
HELSEDIREKTORATET_BASE_URL=https://api.helsedirektoratet.no
HELSEDIREKTORATET_SUBSCRIPTION_KEY=
